# Copy to infra/.env and fill in. Used by infra/compose.yaml. Keep .env out of git.
# These MUST match backend/.env: POSTGRES_PASSWORD == DATABASE_URL password,
# MINIO_ROOT_PASSWORD == S3_SECRET_KEY.
POSTGRES_USER=firenet
POSTGRES_PASSWORD=change-me
POSTGRES_DB=firenet
MINIO_ROOT_USER=firenet
MINIO_ROOT_PASSWORD=change-me
