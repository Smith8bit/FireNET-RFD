# Copy to backend/.env and fill in real values. backend/.env is gitignored.
# Settings with NO default in app/config.py are REQUIRED — the app refuses to
# boot without them (fail fast rather than fall back to an insecure value).

# --- REQUIRED secrets (no in-code default) ---
# Master signing secret for the auth cookie/JWT. Generate a long random value,
# e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
# The password-reset and email-verification token secrets are DERIVED from this.
JWT_SECRET=change-me-to-a-long-random-string

# Bootstrap superuser password (seeded once at first startup). Rotate after first login.
INITIAL_SUPERUSER_PASSWORD=change-me

# Object storage (MinIO/S3) secret key.
S3_SECRET_KEY=change-me

# --- Common overrides (have safe defaults; shown for reference) ---
DATABASE_URL=postgresql+asyncpg://firenet:firenet@localhost:5432/firenet
# Serve only over HTTPS in production; leave true unless you know you need HTTP.
COOKIE_SECURE=true
# Comma/JSON list of allowed web origins.
# CORS_ORIGINS=["https://wildfire.forest.go.th"]
INITIAL_SUPERUSER_USERNAME=adminRFD

# Provision one real dispatcher account per regional office / province at startup
# (random passwords, written to a gitignored seeded_accounts.csv at the repo root).
# Turn on once to provision, distribute the CSV, then set back to false.
SEED_REGIONAL_ACCOUNTS=false

# S3 / MinIO
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=firenet
S3_BUCKET=firenet-fire-evidence
S3_SECURE=false

# Push (Firebase Cloud Messaging) — path to a service-account JSON, optional.
FCM_CREDENTIALS_FILE=
